*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output (if you ever migrate)
.next

# Nuxt.js build / generate output (if you ever migrate)
.nuxt

# Gatsby files (if you ever migrate)
